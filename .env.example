# AdaptLearn Environment Variables
# Copy this file to .env.local and fill in your API keys

# ===========================================
# REQUIRED API KEYS
# ===========================================

# ElevenLabs API Configuration
# Get your API key from: https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Google Cloud / Gemini API Configuration
# Get your API key from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ===========================================
# OPTIONAL CONFIGURATION
# ===========================================

# ElevenLabs Voice ID (defaults to Sarah if not set)
# Find voice IDs at: https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Gemini Model (defaults to gemini-2.0-flash-exp)
GEMINI_MODEL=gemini-2.0-flash-exp

# Site Access Password (server-side only)
SITE_PASSWORD=change-me-before-deploy

# Session secret for HMAC signing
SESSION_SECRET=

# Upstash Redis (rate limiting / session store)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
